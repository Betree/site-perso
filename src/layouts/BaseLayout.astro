---
import '../styles/global.css';
import Header from '../components/Header.astro';
import { site } from '../data/site';

interface Props {
  title?: string;
  description?: string;
  narrow?: boolean;
}

const {
  title = site.title,
  description = site.description,
  narrow = false,
} = Astro.props;

const pageTitle = title === site.title ? title : `${title} · ${site.title}`;
const canonical = new URL(Astro.url.pathname, site.url).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="keywords" content={site.keywords.join(', ')} />
    <meta name="author" content={site.author} />
    <meta name="google-site-verification" content={site.googleSiteVerification} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <link rel="canonical" href={canonical} />
    <link
      rel="alternate"
      type="application/rss+xml"
      title={`${site.title} · Blog`}
      href="/rss.xml"
    />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <title>{pageTitle}</title>
  </head>
  <body>
    <Header />
    <main class:list={['site-main', narrow && 'site-main--narrow']}>
      <slot />
    </main>
    <footer class="site-footer">
      <div>
        © {new Date().getFullYear()} by <a href={site.url}>{site.author}</a>. Licensed under <a href="https://creativecommons.org/licenses/by/4.0/">Creative Commons Attribution 4.0 International</a><img class="site-footer__cc-icon" src="/images/cc/cc.svg" alt="" loading="lazy" /><img class="site-footer__cc-icon" src="/images/cc/by.svg" alt="" loading="lazy" />.
      </div>
    </footer>
  </body>
</html>
