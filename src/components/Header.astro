---
import Avatar from './Avatar.astro';
import { site } from '../data/site';

const pathname = Astro.url.pathname;

function isCurrent(href: string): boolean {
  if (href === '/') return pathname === '/';
  return pathname === href || pathname.startsWith(`${href}/`);
}
---

<header class="site-header">
  <div class="site-header__inner">
    <a class="site-title" href="/">
      <span class="site-title__avatar" aria-hidden="true">
        <Avatar class="site-title__image" alt="" width={48} height={48} />
      </span>
      <span class="site-title__name">{site.title}</span>
    </a>
    <nav aria-label="Main">
      <ul class="site-nav">
        <li>
          <a href="/" aria-current={isCurrent('/') ? 'page' : undefined}>Home</a>
        </li>
        <li>
          <a href="/blog" aria-current={isCurrent('/blog') ? 'page' : undefined}>Blog</a>
        </li>
        <li>
          <a href="/about" aria-current={isCurrent('/about') ? 'page' : undefined}>About</a>
        </li>
      </ul>
    </nav>
  </div>
</header>
