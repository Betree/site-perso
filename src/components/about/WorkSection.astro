---
import Card from '../Card.astro';

const experiences = [
  {
    period: 'October 2024 – Present',
    company: 'Open Finance Consortium',
    role: 'Chief Technology Officer',
    location: 'Remote',
    logo: { src: '/images/about/ofico.png', alt: 'Open Finance Consortium' },
    description:
      'Continuing the development of Open Collective under a non-profit structure. Leading the technical vision and engineering team to build open, transparent, and sustainable financial tools for communities and open source projects worldwide.',
    links: [
      {
        href: 'https://blog.opencollective.com/the-open-collective-platform-is-moving-to-a-community-governed-non-profit/',
        label: 'The Open Collective Platform is moving to a community governed non-profit!',
      },
    ],
    technologies: ['TypeScript', 'NodeJS', 'GraphQL', 'PostgreSQL', 'React'],
  },
  {
    period: 'November 2018 – October 2024',
    company: 'Open Collective',
    role: 'Senior Software Engineer',
    location: 'Remote',
    logo: { src: '/images/about/OpenCollective.svg', alt: 'Open Collective' },
    description:
      'Open Collective allows decentralized communities and open source projects to get funded and to spend their money transparently.',
    technologies: ['TypeScript', 'NodeJS', 'GraphQL', 'Apollo', 'PostgreSQL', 'React'],
  },
  {
    period: 'November 2016 – January 2024',
    company: 'CaptainFact',
    role: 'Founder & Lead Developer',
    logo: { src: '/images/about/CaptainFact.svg', alt: 'CaptainFact' },
    description: 'Collaborative, real-time fact checking platform.',
    links: [
      {
        href: 'https://www.ted.com/talks/benjamin_piouffle_pour_mieux_decider_reprenons_en_main_l_information',
        label: 'TEDxNouméa - Pour mieux décider, reprenons en main l’information',
      },
    ],
    technologies: [
      'Elixir',
      'Phoenix',
      'Absinthe',
      'GraphQL',
      'React',
      'Redux',
      'WebExtension',
    ],
  },
  {
    period: 'September 2015 – September 2016',
    company: 'FactSet',
    role: 'Software Developer',
    location: 'Paris, France',
    logo: { src: '/images/about/factset.png', alt: 'FactSet' },
    technologies: ['C', 'C++', 'C#', 'Python'],
  },
  {
    period: 'September 2013 – July 2014',
    company: 'Numvision',
    role: 'Software Developer',
    location: 'La Ciotat, France',
    logo: { src: '/images/about/numvision.png', alt: 'Numvision' },
    description:
      'Improvement of the main company\'s product "Numsync", a professional solution for file synchronization. Also created a REST API and automatized the build of mobile applications.',
    technologies: ['Java', 'Jakarta EE', 'REST API', 'Android and IOS builds'],
  },
  {
    period: 'July 2012 – December 2012',
    company: 'e-Frogg',
    role: 'Web Developer',
    logo: { src: '/images/about/efrogg.png', alt: 'e-Frogg' },
    description:
      'Internship at a web agency. Development of a SEO analysis tool and work on various websites.',
    technologies: ['PHP', 'JavaScript', 'HTML', 'JQuery', 'MySQL'],
  },
];
---

<Card id="work">
  <h2>Work Experience</h2>

  <div class="work-list">
    {
      experiences.map((job) => (
        <article class="work-entry">
          <div class="work-entry__header">
            <div class="work-entry__logo-wrap">
              <img class="work-entry__logo" src={job.logo.src} alt={job.logo.alt} loading="lazy" />
            </div>

            <div class="work-entry__intro">
              <p class="work-entry__meta">
                <time class="work-entry__period">{job.period}</time>
                {job.location && (
                  <>
                    <span class="work-entry__meta-sep" aria-hidden="true">·</span>
                    <span class="work-entry__location">{job.location}</span>
                  </>
                )}
              </p>
              <h3 class="work-entry__title">
                <span class="work-entry__company">{job.company}</span>
                <span class="work-entry__role">{job.role}</span>
              </h3>
            </div>
          </div>

          {job.description && <p class="work-entry__description">{job.description}</p>}

          {job.links && (
            <ul class="work-entry__links">
              {job.links.map((link) => (
                <li>
                  <a href={link.href} target="_blank" rel="noopener noreferrer">
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          )}

          <ul class="work-entry__tech" aria-label={`Technologies at ${job.company}`}>
            {job.technologies.map((tech) => (
              <li>
                <span class="badge">{tech}</span>
              </li>
            ))}
          </ul>
        </article>
      ))
    }
  </div>
</Card>

<style>
  .work-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .work-entry {
    padding-bottom: var(--space-lg);
    border-bottom: 1px solid var(--color-border);
  }

  .work-entry:last-child {
    padding-bottom: 0;
    border-bottom: none;
  }

  .work-entry__header {
    display: flex;
    align-items: flex-start;
    gap: var(--space-md);
  }

  .work-entry__logo-wrap {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 3.25rem;
    height: 3.25rem;
    padding: var(--space-sm);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    background: var(--color-surface);
  }

  .work-entry__logo {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .work-entry__intro {
    flex: 1;
    min-width: 0;
    padding-top: 0.125rem;
  }

  .work-entry__meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-xs) var(--space-sm);
    margin: 0 0 var(--space-xs);
    font-size: 0.8125rem;
    color: var(--color-muted);
  }

  .work-entry__period,
  .work-entry__location {
    margin: 0;
  }

  .work-entry__meta-sep {
    user-select: none;
  }

  .work-entry__title {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    margin: 0;
    font-size: 1.0625rem;
    font-weight: 600;
    line-height: 1.3;
  }

  .work-entry__company {
    color: var(--color-text);
  }

  .work-entry__role {
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-muted);
  }

  .work-entry__description,
  .work-entry__links {
    margin: var(--space-md) 0 0;
    padding-left: calc(3.25rem + var(--space-md));
    font-size: 0.9375rem;
  }

  .work-entry__description {
    color: var(--color-text);
  }

  .work-entry__links {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    padding-left: calc(3.25rem + var(--space-md));
    list-style: none;
  }

  .work-entry__links a {
    text-decoration: none;
    font-size: 0.875rem;
  }

  .work-entry__links a:hover {
    text-decoration: underline;
  }

  .work-entry__tech {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin: var(--space-md) 0 0;
    padding: 0 0 0 calc(3.25rem + var(--space-md));
    list-style: none;
  }

  @media (max-width: 28rem) {
    .work-entry__description,
    .work-entry__links,
    .work-entry__tech {
      padding-left: 0;
    }
  }
</style>
