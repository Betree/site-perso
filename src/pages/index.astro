---
import { getCollection } from 'astro:content';
import Avatar from '../components/Avatar.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import Card from '../components/Card.astro';
import PostCard from '../components/PostCard.astro';
import SocialLinks from '../components/SocialLinks.astro';
import { site } from '../data/site';
import { sortPostsByDate } from '../utils/blog';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const latestPosts = sortPostsByDate(allPosts).slice(0, 5);
---

<BaseLayout narrow>
  <div class="page-cards">
    <Card class="intro">
      <div class="intro__header">
        <Avatar
          class="intro__image"
          alt="Benjamin Piouffle"
          width={48}
          height={48}
        />
        <h1>{site.title}</h1>
      </div>
      <p>{site.introLead}</p>
      <p>
        I am currently working full-time as a CTO for the Open Finance Consortium, a nonprofit
        developing <a href="https://opencollective.com" target="_blank" rel="noopener noreferrer"
          >Open Collective</a
        >, an open-source platform that helps communities achieve financial sustainability.
      </p>
      <p>
        I am also the founder of <a href="https://captainfact.io" target="_blank" rel="noopener noreferrer"
          >CaptainFact</a
        >, a French nonprofit organization developing open-source and collaborative, real-time
        fact-checking tools for citizens, media organizations, and educational institutions.
      </p>
      <p><strong>{site.introNotAvailable}</strong></p>
    </Card>

    <a class="cta" href="/about#about">
      More about my work
      <svg class="cta__icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
        <path
          d="M4 10h12M11 5l5 5-5 5"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"></path>
      </svg>
    </a>

    <Card title="Latest posts">
      <ul class="post-list">
        {latestPosts.map((post) => <PostCard post={post} />)}
      </ul>
      {latestPosts.length > 0 && (
        <p class="mt-3">
          <a href="/blog/">View all posts</a>
        </p>
      )}
    </Card>

    <Card title="Connect">
      <SocialLinks />
    </Card>
  </div>
</BaseLayout>
